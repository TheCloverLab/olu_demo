{
  "family": "olu-agent-runtime",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "${EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "agent-runtime",
      "image": "749391130736.dkr.ecr.us-west-2.amazonaws.com/olu-agent-runtime:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "8080" },
        { "name": "LLM_BASE_URL", "value": "https://api.kimi.com/coding/v1" },
        { "name": "LLM_MODEL", "value": "kimi-for-coding" },
        { "name": "VOLCENGINE_BASE_URL", "value": "https://ark.cn-beijing.volces.com/api/v3" },
        { "name": "VOLCENGINE_IMAGE_MODEL", "value": "doubao-seedream-5-0-260128" }
      ],
      "secrets": [
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/SUPABASE_URL"
        },
        {
          "name": "SUPABASE_SERVICE_ROLE_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/SUPABASE_SERVICE_ROLE_KEY"
        },
        {
          "name": "LLM_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/LLM_API_KEY"
        },
        {
          "name": "VOLCENGINE_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/VOLCENGINE_API_KEY"
        },
        {
          "name": "FB_ACCESS_TOKEN",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/FB_ACCESS_TOKEN"
        },
        {
          "name": "FB_AD_ACCOUNT_ID",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/FB_AD_ACCOUNT_ID"
        },
        {
          "name": "GOOGLE_PLAY_SERVICE_ACCOUNT_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/GOOGLE_PLAY_SERVICE_ACCOUNT_KEY"
        },
        {
          "name": "GOOGLE_PLAY_PACKAGE_NAME",
          "valueFrom": "arn:aws:ssm:us-west-2:749391130736:parameter/olu/agent-runtime/GOOGLE_PLAY_PACKAGE_NAME"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/olu-agent-runtime",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:8080/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "essential": true
    }
  ]
}
